{
  "name": "antcode",
  "version": "0.7.1",
  "description": "AntCode v0.7.1: Root package layout with safe self-evolving patch artifacts",
  "type": "module",
  "private": true,
  "files": [
    "src",
    "docs",
    "schemas",
    "templates",
    "examples",
    "tests",
    "scripts",
    "README.md",
    "LICENSE",
    "VERSION.md",
    "tsconfig.json"
  ],
  "scripts": {
    "init-state": "node scripts/init-state.mjs",
    "demo": "tsx src/cli.ts run-experiment 8",
    "demo:real": "tsx src/cli.ts run-experiment 12 --real",
    "run-experiment": "tsx src/cli.ts run-experiment",
    "report": "tsx src/cli.ts report",
    "show:policy": "tsx src/cli.ts show-policy",
    "show:genomes": "tsx src/cli.ts show-genomes",
    "show:mutations": "tsx src/cli.ts show-mutations",
    "show:health": "tsx src/cli.ts show-health",
    "test": "node tests/index-crossover-export.test.mjs && tsx tests/storage-error-handling.test.ts && tsx tests/artifact-lifecycle.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
