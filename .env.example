# AntCode real mode configuration (do not put real secrets in this file)
ANTCODE_RUNTIME=pi
ANTCODE_LLM_BASE_URL=https://sub.foxnio.com/v1
ANTCODE_LLM_API_KEY=sk-...
ANTCODE_LLM_MODEL=gpt-5.4

# Safety/concurrency knobs
ANTCODE_CONCURRENCY=1
ANTCODE_MAX_WORKBENCHES=2
ANTCODE_AGENT_TIMEOUT_MS=45000
ANTCODE_AGENT_ABORT_GRACE_MS=1500
ANTCODE_TASKGEN_TIMEOUT_MS=30000
